{
  "expo": {
    "name": "WashXpress",
    "slug": "WashXpress",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "washxpress",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bimsara2k04.washxpress.dev"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "package": "com.washxpress.customer",
        "adaptiveIcon": {
          " monochromeImage": "./assets/images/android-icon-monochrome.png"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.bimsara2k04.WashXpress"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow WashXpress to use your location to find the nearest car wash service.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "API_BASE_URL": "http://localhost:3000",
      "FIREBASE_API_KEY": "AIzaSyBjXus8xIr_Cvjtnm3yV5BR9P1lqYGgahQ",
      "FIREBASE_AUTH_DOMAIN": "washxpress-19b94.firebaseapp.com",
      "FIREBASE_PROJECT_ID": "washxpress-19b94",
      "FIREBASE_STORAGE_BUCKET": "washxpress-19b94.firebasestorage.app",
      "FIREBASE_MESSAGING_SENDER_ID": "1080986101352",
      "FIREBASE_APP_ID": "1:1080986101352:web:93a4a68b81b75c7e377ddd"
    }
  }
}